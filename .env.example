# Local development defaults. Copy to .env when running locally.
DATABASE_URL="file:./dev.db"
NODE_ENV="development"
APP_ENV="local"
APP_VERSION="local"
AI_PROVIDER="mock"
AI_MODEL="mock-medical-agent-v0.1"
AI_TIMEOUT_MS="12000"
AI_FALLBACK_TO_MOCK="true"
MEDICAL_DATA_SOURCE="mock"
NEXT_TELEMETRY_DISABLED="1"
