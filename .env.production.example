# ECS demo deployment example. Copy to .env.production or .env on the server.
# The SQLite file should live on a persistent disk or Docker volume.
DATABASE_URL="file:/app/data/gaoxin-health.db"
SQLITE_DB_PATH="/app/data/gaoxin-health.db"
NODE_ENV="production"
APP_ENV="demo"
APP_VERSION="ecs-demo"
PORT="3000"
NEXT_TELEMETRY_DISABLED="1"

# Set true when you intentionally want every container start to reset demo data.
# Keep false for normal ECS demo usage so operator actions are not lost on restart.
SEED_ON_START="false"
