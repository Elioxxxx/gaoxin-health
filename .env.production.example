# ECS demo deployment example. Copy to .env.production on the server.
# The SQLite file should live on a persistent ECS disk path.
DATABASE_URL="file:/opt/gaoxin-health/data/gaoxin-health.db"
SQLITE_DB_PATH="/opt/gaoxin-health/data/gaoxin-health.db"
NODE_ENV="production"
APP_ENV="demo"
APP_VERSION="ecs-demo"
PORT="3000"
NEXT_TELEMETRY_DISABLED="1"

# Set true only when you intentionally want a deploy to reset demo data.
# Keep false for normal ECS demo usage so operator actions are not lost on restart.
SEED_ON_START="false"
